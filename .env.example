# Service-account mode
GSC_AUTH_MODE=service_account
GSC_KEY_FILE=/absolute/path/to/service-account.json
GSC_DATA_STATE=all
GSC_ENABLE_INDEXING_API=true

# Property selection is normally dynamic: call gsc_properties_list, then pass
# the chosen property as site_url in each tool call. Optional fallback env vars
# exist but are intentionally not shown here to avoid hardcoding one property.

# OAuth mode (optional)
# GSC_AUTH_MODE=oauth
# GSC_OAUTH_SECRETS_FILE=/absolute/path/to/client_secret.json
# GSC_OAUTH_TOKEN_FILE=~/.config/gsc-mcp/oauth-token.json
# GSC_OAUTH_PORT=3847
