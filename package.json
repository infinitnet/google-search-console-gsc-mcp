{
  "name": "@infinitnet/google-search-console-gsc-mcp-server",
  "version": "1.0.1",
  "description": "Infinitnet Google Search Console (GSC) MCP Server for Search Console operations and SEO analysis workflows.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "infinitnet-google-search-console-gsc-mcp-server": "dist/index.js",
    "gsc-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "lint": "tsc -p tsconfig.json --noEmit",
    "test": "npm run build && node --test dist/**/*.test.js",
    "start": "node dist/index.js"
  },
  "keywords": [
    "mcp",
    "google-search-console",
    "search-console",
    "seo",
    "gsc"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/infinitnet/google-search-console-gsc-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/infinitnet/google-search-console-gsc-mcp/issues"
  },
  "homepage": "https://github.com/infinitnet/google-search-console-gsc-mcp#readme",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@googleapis/indexing": "^6.0.1",
    "@googleapis/searchconsole": "^6.0.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "google-auth-library": "^10.6.2",
    "open": "^11.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "typescript": "^6.0.3"
  },
  "files": [
    "dist",
    "!dist/__tests__",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
